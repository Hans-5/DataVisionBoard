{
  "name": "data-vision-board",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "husky"
  },
  "dependencies": {
    "echarts": "^5.5.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.26.0",
    "husky": "^9.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  },
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "eslint --fix --max-warnings=999",
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
